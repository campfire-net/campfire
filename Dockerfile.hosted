FROM golang:1.24-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /cf-mcp ./cmd/cf-mcp

FROM alpine:3.19
RUN apk add --no-cache ca-certificates
COPY --from=build /cf-mcp /usr/local/bin/cf-mcp
EXPOSE 8080
ENTRYPOINT ["cf-mcp", "--http", ":8080", "--sessions-dir", "/data/sessions"]
